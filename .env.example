# Vite client-side env vars (geprefixt met VITE_, zichtbaar in browser)
VITE_SUPABASE_URL="https://<project>.supabase.co"
VITE_SUPABASE_PROJECT_ID="<project-ref>"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon-key-jwt>"

# Edge-function secrets (configureren via Supabase Dashboard → Edge Functions → Secrets)
# Niet in deze file maar als referentie:
#
# SUPABASE_URL                — automatisch beschikbaar in edge runtime
# SUPABASE_SERVICE_ROLE_KEY   — automatisch beschikbaar in edge runtime
# EFLUX_API_KEY               — Bearer JWT van Road
# INTERNAL_FUNCTION_SECRET    — gedeelde secret voor cron/chained edge function calls
# PUBLIC_APP_URL             — publieke app-origin voor uitnodigingslinks in e-mails
# CONFIGURATOR_APP_URL        — configurator-origin, lokaal http://localhost:8081 en later https://config.echarging.nl
# CONFIGURATOR_COOKIE_DOMAIN  — pas zetten na DNS/custom domain, bijvoorbeeld config.echarging.nl
#
# Road / e-Flux niet-geheime configuratie staat op organizations-record in DB:
#   organizations.eflux_provider_id         — provider slug of ObjectId (bv. "NLEFL")
#   organizations.eflux_master_account_id   — optioneel; e-Charging master Account
