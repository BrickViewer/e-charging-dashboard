{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "strict": false,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@echarging/pricing-engine": ["../../packages/pricing-engine/src"],
      "@echarging/api-client": ["../../packages/api-client/src"],
      "@echarging/ui-kit": ["../../packages/ui-kit/src"]
    }
  },
  "include": ["src"]
}
