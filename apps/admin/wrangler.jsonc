{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "echarging-admin",
  "compatibility_date": "2026-06-01",
  // Static-assets-only Worker (geen server-code): serveert de Vite-build.
  // single-page-application -> elke onbekende route valt terug op index.html (200),
  // zodat client-side routing (/admin, /portal, deep links) blijft werken.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
